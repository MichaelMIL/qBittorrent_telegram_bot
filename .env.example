# Telegram
BOT_TOKEN=123456:ABC-your-bot-token-from-botfather
# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_USER_IDS=123456789

# qBittorrent Web UI (enable it in qBittorrent: Preferences -> Web UI)
QBIT_HOST=192.168.1.50
QBIT_PORT=8080
QBIT_USERNAME=admin
QBIT_PASSWORD=adminadmin

# HeBits search (optional). Log in to hebits.net in a browser, open DevTools ->
# Network tab, click any request to hebits.net, and copy the whole "Cookie"
# request header value here.
HEBITS_COOKIE=
